# Leave both unset for local dev — a local SQLite file (./local.db) is used automatically.
# For production (Vercel), create a free Turso database at https://turso.tech and set these:
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Free API key from https://fdc.nal.usda.gov/api-key-signup — powers food name autocomplete.
# Without it, addEntry/deleteEntry still work but searchFood returns no suggestions.
USDA_API_KEY=
